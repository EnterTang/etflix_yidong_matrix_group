# Docker Hub 镜像
WORKER_IMAGE=entergtang/etflix-yidong-worker
WORKER_TAG=latest
WORKER_CONTAINER_NAME=etflix-yidong-worker

# 主服务地址（至少配置一个）
MASTER_URL=https://matrix139.entertang.work/
# 多主服务地址（可选，逗号分隔；配置后会与 MASTER_URL 合并）
MASTER_URLS=

# 授权码管理
AUTH_CODE=CHANGE_ME

# 可选：给 Worker 默认注入 139 登录态
MOBILE_COOKIE_HEADER=
MOBILE_AUTHORIZATION=

WORKER_CODE_KEY='H9&kL#2vP!nQ7z*R@5mX9$jB'

# 数据目录映射（宿主机路径 -> /app/data）
WORKER_DATA_HOST_PATH=./data

# 可选：登录态巡检参数
AUTH_HEALTH_CHECK_INTERVAL_MS=300000
AUTH_EXPIRY_SKEW_MS=60000
AUTH_EXPIRY_NOTIFY_BEFORE_MS=604800000
AUTH_EXPIRY_NOTIFY_COOLDOWN_MS=43200000
# 配置 Telegram 后可接收到期提醒，也可用指令远程刷新登录态
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_API_BASE=https://api.telegram.org
TELEGRAM_POLL_TIMEOUT_SEC=25
TELEGRAM_POLL_RETRY_DELAY_MS=5000
WORKER_LOG_TIMEZONE=Asia/Shanghai
MOBILE_CRAWL_HTTP_CONCURRENCY=4
MOBILE_SHARE_API_TIMEOUT_SEC=20
MOBILE_SHARE_API_RETRIES=2

# 可选：任务超时（毫秒，主服务侧）
MOBILE_CRAWL_TIMEOUT_MS=180000
MOBILE_DIRECT_LINK_TIMEOUT_MS=40000

# 可选：Python 执行器路径，保护镜像默认值如下
PYTHON_WORKER_PATH=/app/protected/mobile_cloud_share_runner.py
