# Docker Hub 镜像
WORKER_IMAGE=entergtang/etflix-yidong-worker
WORKER_TAG=latest
WORKER_CONTAINER_NAME=etflix-yidong-worker

# 主服务地址（至少配置一个）
MASTER_URL=https://matrix139.entertang.work/
# 多主服务地址（可选，逗号分隔；配置后会与 MASTER_URL 合并）
MASTER_URLS=

# 授权码管理
AUTH_CODE=CHANGE_ME

# 可选：给 Worker 默认注入 139 登录态
MOBILE_COOKIE_HEADER=
MOBILE_AUTHORIZATION=

WORKER_CODE_KEY='H9&kL#2vP!nQ7z*R@5mX9$jB'

# 数据目录映射（宿主机路径 -> /app/data）
WORKER_DATA_HOST_PATH=./data

# 可选：登录态巡检参数
AUTH_HEALTH_CHECK_INTERVAL_MS=300000
AUTH_EXPIRY_SKEW_MS=60000
WORKER_LOG_TIMEZONE=Asia/Shanghai

# 可选：Python 执行器路径，保护镜像默认值如下
PYTHON_WORKER_PATH=/app/protected/mobile_cloud_share_runner.py

